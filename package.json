{
  "name": "demoPratical",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android1": "react-native run-android",
    "android": "reset && npm run removeGenerated && npm run androidList && react-native run-android -- -FIRAnalyticsDebugEnabled -FIRAnalyticsDebugEnabled",
    "android1Release": "react-native run-android --variant release #android",
    "iPhone17Pro": "react-native run-ios --simulator='iPhone 17 Pro'",
    "androidNPX": "npm run cleanGradle && reset && npm run androidList && npx react-native run-android",
    "androidRelease": "reset && npm run removeGenerated && npm run androidList && react-native run-android --mode=release -- -FIRAnalyticsDebugEnabled -FIRAnalyticsDebugEnabled",
    "ios": "reset && react-native run-ios --simulator='iPhone 17 Pro' -- -FIRAnalyticsDebugEnabled -FIRAnalyticsDebugEnabled",
    "lint": "eslint .",
    "test": "jest",
    "abortMerge": "git merge --abort",
    "pullOrigin": "git pull origin",
    "pushOrigin": "git push origin",
    "openAndroidStudio": "open -a /Applications/Android\\ Studio.app",
    "openXcode": "cd ios && open demoPratical.xcworkspace",
    "updateAsset": "npx react-native-asset",
    "getSHA1Report": "cd android && ./gradlew signingReport && cd ..",
    "clearCache": "npm start -- --reset-cache",
    "npmForce": "npm cache clean --force",
    "npmVerify": "npm cache verify",
    "installAab": "chmod 777 ./src/scripts/installAab.sh && ./src/scripts/installAab.sh",
    "checkCocoapodsVersion": "sudo gem which cocoapods",
    "cleanPodsCache": "pod cache clean --all",
    "runBoth": "reset && npm run ios && npm run android",
    "cleanXcode": "rm -rf ./ios/build && cd ios && xcodebuild clean && cd ../",
    "cleanGradle": "cd android && ./gradlew clean && cd ../",
    "generateKeyStore": "keytool -genkey -v -keystore debug-prod.keystore -alias androiddebugkey -storepass android -keypass android -keyalg RSA -validity 14000",
    "removeDerivedData": "rm -rf ~/Library/Developer/Xcode/DerivedData/*",
    "clearAll": "npm run clearCache && npm run clearRoot",
    "iPhone8Plus": "react-native run-ios --simulator='iPhone 14 Pro'",
    "start": "react-native start",
    "reverseAdb": "adb reverse tcp:8081 tcp:8081",
    "updateGems": "bundle install",
    "clearRoot": "npm run cleanGradle && npm run cleanXcode && sleep 5",
    "clearNodeCache": "npm start -- --reset-cache && npm run clearWatch",
    "clearWatch": "command -v watchman &> /dev/null && watchman watch-del-all || echo 'Watchman is not installed.' && sleep 2",
    "clearForce": "npm cache clean --force",
    "common": "reset && sleep 2 && npm run removeOld && sleep 2 && npm run nodeInstall && npm run podInstall && npm run clearRoot && sleep 1",
    "nodeInstall": "npm run removeNodes && npm install --legacy-peer-deps",
    "installRelease": "cd android && ./gradlew installRelease && cd ../",
    "removeGenerated": "rm -rf ./android/app/build/generated && sleep 2",
    "assembleRelease": "npm run removeGenerated && cd android && ./gradlew assembleRelease && cd ../",
    "bundleRelease": "cd android && ./gradlew bundleRelease && cd ../",
    "makeAPK": "npm run assembleRelease",
    "makeAAB": "npm run makeAPK && npm run bundleRelease",
    "podInstall": "cd ios && pod install && cd ../",
    "podUninstall": "cd ios && pod deintegrate && cd ../",
    "podSetup": "npm run removePodLock && npm run podUninstall && npm run podInstall",
    "removeNodes": "rm -rf node_modules && rm -rf ./ios/Pods && sleep 10",
    "removePodLock": "rm -f ./ios/Podfile.lock && sleep 2",
    "removePkgLock": "rm -f package-lock.json && sleep 2",
    "commitNoVerify": "git commit -m 'WIP' --no-verify",
    "removeOld": "npm run removeNodes && npm run removePodLock && npm run removePkgLock",
    "androidList": "adb devices",
    "uninstallApp": "adb uninstall com.demopratical",
    "iPhoneList": "xcrun simctl list devices",
    "generateKey": "node src/utils/encryption/generate.js",
    "local": "ENV=local ./src/scripts/envscript.sh && sleep 1",
    "dev": "ENV=dev ./src/scripts/envscript.sh && sleep 1",
    "stage": "ENV=stage ./src/scripts/envscript.sh && sleep 1",
    "uat": "ENV=uat ./src/scripts/envscript.sh && sleep 1",
    "prod": "ENV=prod ./src/scripts/envscript.sh && sleep 1",
    "fixGen": "npm run removeDerivedData && npm run clearCache && rm -rf ./android/build && rm -rf ./android/app/build && rm -rf ./ios/build && sleep 10 && npm run podInstall && sleep 3",
    "fixNinja": "npm run clearWatch && rm -rf node_modules && rm -rf $TMPDIR/metro-* && rm -rf android/.gradle && rm -rf android/app/build && rm -rf android/build && rm -rf android/app/.cxx && rm -rf ios/build && rm -rf android/.cxx && npm cache clean --force sleep 10 npm run nodeInstall && npm run updateGems && npm run clearRoot && sleep 1",
    "checkTs": "reset && chmod 777 .githooks/pre-commit && sh .githooks/pre-commit 1",
    "formatProjectSrc": "eslint --fix src",
    "build:ios": "react-native bundle --entry-file='index.js' --bundle-output='./ios/main.jsbundle' --dev=false --platform='ios'",
    "postinstall": "git config core.hooksPath .githooks "
  },
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/bottom-tabs": "^7.18.4",
    "@react-navigation/native": "^7.3.5",
    "@react-navigation/native-stack": "^7.17.7",
    "@react-navigation/stack": "^7.10.7",
    "@reduxjs/toolkit": "^2.12.0",
    "@shopify/flash-list": "^2.3.2",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "crypto-js": "^4.2.0",
    "formik": "^2.4.9",
    "i18next": "^26.3.4",
    "lodash": "^4.18.1",
    "react": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-config": "^1.6.1",
    "react-native-config-encrypted": "^1.0.2",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-mmkv": "^3.0.0-beta.5",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-size-matters": "^0.4.2",
    "react-native-svg": "^15.15.5",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "^0.10.0",
    "react-redux": "^9.3.0",
    "reactotron-react-native": "^5.2.0",
    "use-latest-callback": "^0.3.4",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
